{
	"info": {
		"_postman_id": "eventsphere-demo-collection",
		"name": "EventSphere API - End-to-End Flow",
		"description": "Demonstration of the EventSphere ticketing platform: Login -> Catalog -> Seating -> Order -> Ticket.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{GATEWAY_URL}}/api/v1/auth/login",
							"host": [
								"{{GATEWAY_URL}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Catalog",
			"item": [
				{
					"name": "Get Events",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{GATEWAY_URL}}/api/v1/catalog/events",
							"host": [
								"{{GATEWAY_URL}}"
							],
							"path": [
								"api",
								"v1",
								"catalog",
								"events"
							]
						}
					}
				}
			]
		},
		{
			"name": "3. Booking Flow",
			"item": [
				{
					"name": "Place Order (Saga)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{JWT_TOKEN}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"eventId\": 1,\n    \"seatIds\": [101, 102],\n    \"paymentMethodId\": \"pm_card_visa\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{GATEWAY_URL}}/api/v1/orders",
							"host": [
								"{{GATEWAY_URL}}"
							],
							"path": [
								"api",
								"v1",
								"orders"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "GATEWAY_URL",
			"value": "http://localhost:8080"
		},
		{
			"key": "JWT_TOKEN",
			"value": "your-token-here"
		}
	]
}
