    "csv-parser": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "prisma": "^5.0.0",
    "@types/node": "^18.0.0",
    "@types/express": "^4.17.0",
